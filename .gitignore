# Ambiente virtuale
venv/
.venv/
env/

# Variabili d'ambiente (contengono credenziali)
.env
*.env

# Database locale
*.db
*.sqlite

# Google credentials locali (solo file di credenziali, non tutti i .json:
# i dati di preset e la field-map PDF devono restare versionati)
*credentials*.json
*service-account*.json
client_secret*.json

# Materiale di riferimento del prototipo (non fa parte dell'app deployata)
CRM AM/

# Backup DB locali (contengono dati pazienti reali)
gestionale.backup.*.db
backup_*.json

# Dati reali / documenti (non vanno versionati)
*.xlsx
*.docx

# Config locale dell'editor / Claude
.claude/

# Upload PDF locali
uploads/

# Log
*.log
server.log

# Python cache
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store
